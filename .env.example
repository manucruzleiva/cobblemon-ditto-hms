# ─── Cobblemon Ditto HMs — environment variables ─────────────────────────────
# Copy this file to .env (never commit .env — it's in .gitignore)

# ── Publishing ────────────────────────────────────────────────────────────────
# Modrinth API token — https://modrinth.com/settings/pats
MODRINTH_TOKEN=

# CurseForge API token — https://authors.curseforge.com/account/api-keys
CURSEFORGE_TOKEN=

# ── Discord → GitHub Issues bot ───────────────────────────────────────────────
# GitHub PAT with repo + issues write access (for the intake bot)
GITHUB_TOKEN=

# Discord bot token — https://discord.com/developers/applications
DISCORD_TOKEN=

# Discord Guild (server) ID
DISCORD_GUILD_ID=

# Forum channel ID where users post bug reports / features
DISCORD_BUG_CHANNEL_ID=
DISCORD_FEATURE_CHANNEL_ID=

# GitHub repo where issues are created (format: owner/repo)
GITHUB_REPO=manucruzleiva/cobblemon-ditto-hms
